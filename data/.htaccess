# Block ALL direct browser access to this directory.
# PHP (subscribe.php) can still read/write files here from server-side code.

<IfModule mod_authz_core.c>
    # Apache 2.4+
    Require all denied
</IfModule>

<IfModule !mod_authz_core.c>
    # Apache 2.2 fallback
    Order deny,allow
    Deny from all
</IfModule>
